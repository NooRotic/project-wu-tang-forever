{
  "name": "project-grabber",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "scrape": "node scrape-lyrics.js",
    "scrape:wu-tang": "node scrape-lyrics.js --artist \"Wu-Tang Clan\" --slug Wu-tang-clan",
    "scrape:wu-tang:chunk1": "node scrape-lyrics.js --artist \"Wu-Tang Clan\" --slug Wu-tang-clan --chunk-size 25 --offset 0",
    "scrape:wu-tang:chunk2": "node scrape-lyrics.js --artist \"Wu-Tang Clan\" --slug Wu-tang-clan --chunk-size 25 --offset 25",
    "scrape:wu-tang:chunk3": "node scrape-lyrics.js --artist \"Wu-Tang Clan\" --slug Wu-tang-clan --chunk-size 25 --offset 50",
    "enrich:wu-tang": "node scrape-lyrics.js --artist \"Wu-Tang Clan\" --slug Wu-tang-clan --enrich-only",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:artists": "node scripts/build-artists.js"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "cheerio": "^1.1.2",
    "dotenv": "^17.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^28.1.0",
    "vite": "^7.0.4",
    "vitest": "^4.0.18"
  }
}
