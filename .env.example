# Genius API credentials — required for --enrich / --enrich-only scraper flags.
# Adds pageviews, producers, writers, featured artists, and release dates to scraped data.
#
# Create a free API client at: https://genius.com/api-clients
# Copy this file to .env and fill in your values.

GENIUS_CLIENT_ID=your_client_id_here
GENIUS_CLIENT_SECRET=your_client_secret_here
